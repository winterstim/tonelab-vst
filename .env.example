# Runtime API/Web endpoints injected by Rust into the embedded UI.
TONELAB_API_BASE_URL=https://api.tonelab.dev/api/v1
TONELAB_WEB_BASE_URL=https://tonelab.dev
# Backward-compatible fallback for web base URL.
FRONTEND_URL=https://tonelab.dev

# Optional API prefix injected to the embedded UI.
# Leave empty unless backend is mounted without /api/v1 in base URL.
TONELAB_API_PREFIX=

# Optional metadata overrides at build time.
TONELAB_VENDOR_URL=https://tonelab.dev
TONELAB_SUPPORT_EMAIL=tonelabvst@gmail.com
TONELAB_DEFAULT_API_BASE_URL=https://api.tonelab.dev/api/v1
TONELAB_DEFAULT_WEB_BASE_URL=https://tonelab.dev
TONELAB_DEFAULT_API_PREFIX=

# Security controls.
# Comma-separated allowlist of hosts for external URL open requests.
# Example: tonelab.dev,api.tonelab.dev
TONELAB_ALLOWED_EXTERNAL_HOSTS=
# true/false, 1/0, yes/no, on/off. Defaults to true in debug builds.
TONELAB_ENABLE_DEVTOOLS=false

# Optional absolute path for plugin logs.
TONELAB_LOG_FILE_PATH=

# Evergreen sync (backend-driven WASM runtime)
TONELAB_EVERGREEN_ENABLED=true
TONELAB_EVERGREEN_SYNC_URL=http://localhost:8080/vst/sync
# Optional override for the UI URL (normally comes from /vst/sync assets.web_ui_url)
TONELAB_EVERGREEN_WEB_UI_URL=
# Base64 raw 32-byte Ed25519 public key used to verify incoming wasm bundles.
# For local dev key generation: backend/security/sign_bundle.sh
TONELAB_EVERGREEN_ED25519_PUBLIC_KEY_B64=
# In debug/dev this defaults to true, in release set explicit false for strict verification.
TONELAB_EVERGREEN_ALLOW_UNSIGNED=true
